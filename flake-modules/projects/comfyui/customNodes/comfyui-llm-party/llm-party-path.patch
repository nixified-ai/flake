+def get_system_info():
+    system_info = {
+        "gpu": False,
+        "cuda_version": None,
+        "avx2": False,
+        "python_version": get_python_version(),
+        "os": platform.system(),
+        "os_bit": platform.architecture()[0].replace("bit", ""),
+        "platform_tag": None,
+        "metal": False  # 添加metal参数
